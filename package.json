{
  "name": "gemini-low-code-app-builder",
  "version": "1.0.0",
  "description": "A low-code app builder with AI features",
  "main": "index.js",
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "jest",
    "test:drag": "jest --testPathPattern='drag.test'",
    "test:ai": "jest --testPathPattern='geminiService\\.test'",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e-ui": "playwright test --ui",
    "test:e2e-report": "playwright show-report",
    "test:e2e-coverage": "playwright test && nyc report --reporter=text --reporter=html",
    "test:e2e:input": "playwright test e2e/form-components-properties.spec.ts --grep \"INPUT:\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@google/genai": "^1.43.0",
    "@playwright/test": "^1.44.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.24",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jszip": "^3.10.1",
    "marked": "^17.0.0",
    "nyc": "^15.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5",
    "v8-to-istanbul": "^9.1.1",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@uipath/uipath-typescript": "^1.0.0-beta.16",
    "highlight.js": "^11.11.1",
    "html-to-image": "^1.11.13",
    "monaco-editor": "^0.55.1",
    "openai": "^6.9.1",
    "zustand": "^5.0.11"
  }
}
